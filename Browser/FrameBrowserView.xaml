<UserControl x:Class="TimberDraw.Browser.FrameBrowserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI" FontSize="12"
             Background="{DynamicResource TdBg}">
    <!-- Colors come from the shared Theme via ThemeWpf.Apply (the Td* resources) so this WPF
         surface tracks the same COLORTHEME-driven palette as the WinForms tabs. -->
    <UserControl.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource TdSurface}"/>
            <Setter Property="Foreground" Value="{DynamicResource TdFg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource TdBorder}"/>
        </Style>
        <Style TargetType="ListView">
            <Setter Property="Background" Value="{DynamicResource TdSurface}"/>
            <Setter Property="Foreground" Value="{DynamicResource TdFg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource TdBorder}"/>
        </Style>

        <!-- Buttons: the same flat dark look as the WinForms tabs (the default WPF chrome
             stays light no matter what Background is set, so the template is replaced).
             Pressed = accent with black text, matching the grid-selection convention. -->
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource TdFg}"/>
            <Setter Property="Background" Value="{DynamicResource TdButton}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource TdBorder}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource TdHeader}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource TdAccent}"/>
                                <Setter Property="Foreground" Value="Black"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource TdSubtle}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox (the Kind selector): dark chrome needs a replaced template too; the
             system template paints its own light gradient regardless of Background. -->
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource TdFg}"/>
            <Setter Property="Background" Value="{DynamicResource TdSurface}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource TdBorder}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Focusable="False" ClickMode="Press"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1">
                                            <Path HorizontalAlignment="Right" VerticalAlignment="Center"
                                                  Margin="0,0,7,0" Data="M 0 0 L 4 4 L 8 0 Z"
                                                  Fill="{DynamicResource TdSubtle}"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Margin="6,2,22,2" VerticalAlignment="Center" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>
                            <Popup IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom" AllowsTransparency="True">
                                <Border Background="{DynamicResource TdSurface}"
                                        BorderBrush="{DynamicResource TdBorder}" BorderThickness="1"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="220">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource TdFg}"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource TdAccent}"/>
                                <Setter Property="Foreground" Value="Black"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <DockPanel LastChildFill="True" Margin="6" TextElement.Foreground="{DynamicResource TdFg}">

        <!-- Header: status line -->
        <DockPanel DockPanel.Dock="Top" LastChildFill="True" Margin="0,0,0,6">
            <TextBlock Text="{Binding Status}" VerticalAlignment="Center" Foreground="{DynamicResource TdSubtle}"/>
        </DockPanel>

        <!-- Filter (type / handle); also the ElementHost keyboard-focus spike -->
        <DockPanel DockPanel.Dock="Top" LastChildFill="True" Margin="0,0,0,6">
            <TextBlock DockPanel.Dock="Left" Text="Filter" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"/>
        </DockPanel>

        <!-- Bottom action row: full-span buttons (the shared bottom-bar idiom). -->
        <UniformGrid DockPanel.Dock="Bottom" Columns="3" Margin="0,6,0,0">
            <Button Content="Refresh" Margin="2" Padding="0,4" Command="{Binding RefreshCommand}"/>
            <Button Content="Apply"   Margin="2" Padding="0,4" Command="{Binding ApplyCommand}"/>
            <Button Content="Assign"  Margin="2" Padding="0,4" Command="{Binding AssignCommand}"/>
        </UniformGrid>

        <!-- Property editor + assign target: fully STACKED labeled rows, one edit box per
             row, never side by side. Selecting a single row LOADS its current section +
             assembly here (the review side); Apply re-sections, Assign addresses the timber
             (Frame > Bent / Wall+Bay / Floor via TAssign). -->
        <Border DockPanel.Dock="Bottom" BorderBrush="{DynamicResource TdBorder}" BorderThickness="0,1,0,0"
                Padding="0,6,0,0" Margin="0,6,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="52"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Type" VerticalAlignment="Center" Margin="0,0,6,4"/>
                <TextBox   Grid.Row="0" Grid.Column="1" Margin="0,0,0,4"
                           Text="{Binding EditType, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="W" VerticalAlignment="Center" Margin="0,0,6,4"/>
                <TextBox   Grid.Row="1" Grid.Column="1" Margin="0,0,0,4"
                           Text="{Binding EditW, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="D" VerticalAlignment="Center" Margin="0,0,6,4"/>
                <TextBox   Grid.Row="2" Grid.Column="1" Margin="0,0,0,4"
                           Text="{Binding EditD, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Frame" VerticalAlignment="Center" Margin="0,0,6,4"/>
                <TextBox   Grid.Row="3" Grid.Column="1" Margin="0,0,0,4"
                           Text="{Binding AsmFrame, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Grid.Row="4" Grid.Column="0" Text="Kind" VerticalAlignment="Center" Margin="0,0,6,4"/>
                <ComboBox  Grid.Row="4" Grid.Column="1" Margin="0,0,0,4"
                           ItemsSource="{Binding AsmKinds}" SelectedItem="{Binding AsmKind}"/>
                <TextBlock Grid.Row="5" Grid.Column="0" Text="Owner" VerticalAlignment="Center" Margin="0,0,6,4"/>
                <TextBox   Grid.Row="5" Grid.Column="1" Margin="0,0,0,4"
                           Text="{Binding AsmOwner, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Grid.Row="6" Grid.Column="0" Text="{Binding AsmExtraLabel}" VerticalAlignment="Center" Margin="0,0,6,4"/>
                <TextBox   Grid.Row="6" Grid.Column="1" Margin="0,0,0,4" IsEnabled="{Binding AsmExtraEnabled}"
                           Text="{Binding AsmBay, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
        </Border>

        <!-- Timber list, grouped Frame -> Owner (bents, walls, floors) -> Bay. Selecting rows
             grip-highlights them in the drawing (no view change) and loads the last-picked row's
             assembly; double-click zooms; ctrl/shift multi-select feeds Assign. -->
        <ListView x:Name="TimberList"
                  ItemsSource="{Binding Timbers}"
                  SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                  IsSynchronizedWithCurrentItem="True"
                  SelectionChanged="TimberList_SelectionChanged"
                  MouseDoubleClick="TimberList_MouseDoubleClick">
            <ListView.GroupStyle>
                <!-- Level 0: Frame header (bold). -->
                <GroupStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" FontWeight="Bold"
                                       Margin="2,6,0,2" Foreground="{DynamicResource TdAccent}"/>
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
                <!-- Level 1: Owner header (Bent N / Wall X). -->
                <GroupStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                       Margin="14,3,0,1" Foreground="{DynamicResource TdFg}"/>
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
                <!-- Level 2: Bay sub-header (walls only). Collapses when empty so bent members are flat. -->
                <GroupStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" FontStyle="Italic"
                                       Margin="28,1,0,1" Foreground="{DynamicResource TdSubtle}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Name}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
            </ListView.GroupStyle>
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Grid" Width="64"  DisplayMemberBinding="{Binding GridRef}"/>
                    <GridViewColumn Header="Type" Width="86"  DisplayMemberBinding="{Binding Type}"/>
                    <GridViewColumn Header="Size" Width="92"  DisplayMemberBinding="{Binding Size}"/>
                    <GridViewColumn Header="Handle" Width="60" DisplayMemberBinding="{Binding Handle}"/>
                </GridView>
            </ListView.View>
        </ListView>
    </DockPanel>
</UserControl>
