<UserControl x:Class="TimberDraw.Browser.FrameBrowserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI" FontSize="12">
    <DockPanel LastChildFill="True" Margin="6">

        <!-- Header: status + refresh -->
        <DockPanel DockPanel.Dock="Top" LastChildFill="True" Margin="0,0,0,6">
            <Button DockPanel.Dock="Right" Content="Refresh" Padding="10,2"
                    Command="{Binding RefreshCommand}"/>
            <TextBlock Text="{Binding Status}" VerticalAlignment="Center" Foreground="#444"/>
        </DockPanel>

        <!-- Filter (type / handle); also the ElementHost keyboard-focus spike -->
        <DockPanel DockPanel.Dock="Top" LastChildFill="True" Margin="0,0,0,6">
            <TextBlock DockPanel.Dock="Left" Text="Filter" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"/>
        </DockPanel>

        <!-- Property editor: re-section the selected timber, write back + regenerate -->
        <Border DockPanel.Dock="Bottom" BorderBrush="#CCC" BorderThickness="0,1,0,0"
                Padding="0,6,0,0" Margin="0,6,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Type" VerticalAlignment="Center" Margin="0,0,6,4"/>
                <TextBox   Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3" Margin="0,0,0,4"
                           Text="{Binding EditType, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="W" VerticalAlignment="Center" Margin="0,0,6,4"/>
                <TextBox   Grid.Row="1" Grid.Column="1" Margin="0,0,8,4"
                           Text="{Binding EditW, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Grid.Row="1" Grid.Column="2" Text="D" VerticalAlignment="Center" Margin="0,0,6,4"/>
                <TextBox   Grid.Row="1" Grid.Column="3" Margin="0,0,0,4"
                           Text="{Binding EditD, UpdateSourceTrigger=PropertyChanged}"/>

                <Button Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4" Content="Apply"
                        HorizontalAlignment="Right" Padding="14,2"
                        Command="{Binding ApplyCommand}"/>
            </Grid>
        </Border>

        <!-- Timber list, grouped Frame -> Owner (bents then walls) -> Bay; selecting a row zooms -->
        <ListView ItemsSource="{Binding Timbers}"
                  SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                  IsSynchronizedWithCurrentItem="True">
            <ListView.GroupStyle>
                <!-- Level 0: Frame header (bold). -->
                <GroupStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" FontWeight="Bold"
                                       Margin="2,6,0,2" Foreground="#205080"/>
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
                <!-- Level 1: Owner header (Bent N / Wall X). -->
                <GroupStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                       Margin="14,3,0,1" Foreground="#333"/>
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
                <!-- Level 2: Bay sub-header (walls only). Collapses when empty so bent members are flat. -->
                <GroupStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" FontStyle="Italic"
                                       Margin="28,1,0,1" Foreground="#666">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Name}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
            </ListView.GroupStyle>
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Grid" Width="46"  DisplayMemberBinding="{Binding GridRef}"/>
                    <GridViewColumn Header="Type" Width="86"  DisplayMemberBinding="{Binding Type}"/>
                    <GridViewColumn Header="Size" Width="92"  DisplayMemberBinding="{Binding Size}"/>
                    <GridViewColumn Header="Handle" Width="60" DisplayMemberBinding="{Binding Handle}"/>
                </GridView>
            </ListView.View>
        </ListView>
    </DockPanel>
</UserControl>
